# ─── Required ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway adds this automatically via the DB plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret key for JWT signing — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret

# Port the server listens on (Railway sets this automatically)
PORT=3000

# ─── Optional / Features ─────────────────────────────────────────────────────
# Enable AI auto-replies via OpenAI
OPENAI_API_KEY=

# Enable the Anthropic AI assistant in the admin panel
ANTHROPIC_API_KEY=

# Node environment (Railway sets this to "production" automatically)
NODE_ENV=production
